<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Kright</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Kright</string>
	<key>CFBundlePackageType</key>
	<string>BNDL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSUIElement</key>
	<true/>
	<key>NSHumanReadableCopyright</key>
	<string></string>
	<!-- Sparkle auto-update. The feed must be reachable over HTTPS by every
	     installed copy; raw.githubusercontent.com works once the repo is public
	     (otherwise host appcast.xml + the DMG somewhere public and update this URL). -->
	<key>SUFeedURL</key>
	<string>https://raw.githubusercontent.com/walteryaron/Kright/main/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>DtqktTmJUAf7h9aEDEtWHCsEHpkJrIERlRLRny8AbnM=</string>
	<!-- SUEnableAutomaticChecks is intentionally NOT set: Sparkle then shows its
	     first-run "Check for updates automatically?" prompt, so the user consents
	     to the only network call this otherwise-offline app makes. -->
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
</dict>
</plist>
