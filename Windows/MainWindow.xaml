<Window x:Class="Kright.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kright" Width="460" Height="640"
        Background="#0D0D0D" WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#DDDDDD"/></Style>
    </Window.Resources>

    <TabControl x:Name="Tabs" Background="#0D0D0D" BorderThickness="0">

        <!-- DETECT (developer tool — hidden unless Debug mode is on) -->
        <TabItem x:Name="DetectTab" Header="Detect">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                <StackPanel>
                    <TextBlock Text="FOCUSED FIELD" FontWeight="Bold" FontSize="11" Foreground="#777"/>
                    <TextBlock x:Name="AppLabel" Margin="0,4,0,10" Foreground="#999"/>

                    <Border Background="#161616" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="WRONG-LAYOUT FIX" FontWeight="Bold" FontSize="11" Foreground="#888"/>
                            <TextBlock x:Name="TypedText" Margin="0,6,0,0" Foreground="#CCC"/>
                            <TextBlock x:Name="ConvertedText" Margin="0,4,0,0" FontSize="18"
                                       FontWeight="Bold" Foreground="#FFD166"/>
                            <TextBlock x:Name="GibberishText" Margin="0,4,0,0" FontSize="11"/>
                            <Button x:Name="ReplaceButton" Content="Replace in field" Margin="0,10,0,0"
                                    HorizontalAlignment="Left" Click="ReplaceButton_Click"/>
                            <TextBlock x:Name="ReplaceResult" Margin="0,6,0,0" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="LANGUAGES" FontWeight="Bold" FontSize="11" Foreground="#777"/>
                    <TextBlock x:Name="LanguagesText" Margin="0,4,0,0" Foreground="#CCC"/>

                    <TextBlock Text="DETECTED TYPE" FontWeight="Bold" FontSize="11" Foreground="#777" Margin="0,12,0,0"/>
                    <TextBlock x:Name="GuessText" Margin="0,4,0,0" FontSize="15" FontWeight="Bold" Foreground="#88CC88"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- SETTINGS -->
        <TabItem Header="Settings">
            <StackPanel Margin="16">
                <TextBlock Text="Fix-layout shortcut" FontWeight="SemiBold"/>
                <TextBlock Text="Press this anywhere to fix the focused field's last word."
                           Foreground="#888" FontSize="11" Margin="0,2,0,6" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal">
                    <Border Background="#1F1F1F" CornerRadius="6" Padding="10,5">
                        <TextBlock x:Name="HotkeyText" FontFamily="Consolas" Foreground="White"/>
                    </Border>
                    <Button x:Name="RecordButton" Content="Change…" Margin="8,0,0,0" Click="RecordButton_Click"/>
                </StackPanel>

                <Separator Margin="0,12"/>

                <TextBlock Text="Auto keyboard language" FontWeight="SemiBold"/>
                <CheckBox x:Name="AutoLangCheck" Margin="0,6,0,0" Foreground="#CCC"
                          Content="Switch to English on email / URL / password fields"
                          Click="AutoLangCheck_Click"/>
                <TextBlock x:Name="AutoLangStatus" Foreground="#88CC88" FontSize="11" Margin="0,4,0,0"/>

                <Separator Margin="0,12"/>

                <TextBlock Text="Developer" FontWeight="SemiBold"/>
                <CheckBox x:Name="DebugCheck" Margin="0,6,0,0" Foreground="#CCC"
                          Content="Debug mode — show the Detect tab" Click="DebugCheck_Click"/>

                <Separator Margin="0,12"/>

                <TextBlock Text="Privacy" FontWeight="SemiBold"/>
                <TextBlock Foreground="#AAAAAA" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"
                           Text="Kright never sends, stores, or sells your data — everything happens on your PC, only to fix the word you just typed."/>
                <TextBlock Foreground="#8BBE8B" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"
                           Text="• No network — it makes zero internet requests, ever."/>
                <TextBlock Foreground="#8BBE8B" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"
                           Text="• No storage — what you type is never logged or saved to disk."/>
                <TextBlock Foreground="#8BBE8B" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"
                           Text="• Password-safe — it stops listening on password fields."/>
                <TextBlock Foreground="#8BBE8B" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"
                           Text="• Open source — verify every word of this in the code on GitHub."/>

                <Separator Margin="0,12"/>

                <TextBlock Text="About" FontWeight="SemiBold"/>
                <TextBlock x:Name="VersionText" Foreground="#CCC" Margin="0,6,0,0"/>
                <TextBlock Text="Keyboard done right."
                           Foreground="#888" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"/>
                <TextBlock Margin="0,6,0,0" FontSize="11">
                    <Hyperlink NavigateUri="https://github.com/walteryaron/Kright"
                               RequestNavigate="Hyperlink_RequestNavigate">View on GitHub</Hyperlink>
                    <Run Text="   ·   by Yaron Walter" Foreground="#888"/>
                </TextBlock>

                <Separator Margin="0,12"/>

                <Button Content="Quit Kright" HorizontalAlignment="Left" Click="Quit_Click"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
